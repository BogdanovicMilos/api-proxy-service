ENV=local

# Provider selection
SPORTS_PROVIDER=openliga

# OpenLiga adapter
OPENLIGA_BASE_URL=https://api.openligadb.de
OPENLIGA_TIMEOUT_SECONDS=10.0

# Rate limiting (token bucket)
OPENLIGA_RATE_LIMIT_PER_SECOND=5.0
OPENLIGA_RATE_LIMIT_BURST=10

# Exponential backoff
OPENLIGA_MAX_RETRIES=3
OPENLIGA_BACKOFF_BASE_SECONDS=0.2
OPENLIGA_BACKOFF_MAX_SECONDS=5.0
OPENLIGA_BACKOFF_JITTER_SECONDS=0.1

# Logging
LOG_BODY_TRUNCATE_CHARS=512
